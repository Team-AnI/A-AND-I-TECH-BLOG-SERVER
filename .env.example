# For local docker compose usage
IMAGE_URI=tech-blog:local
POSTGRES_DB=tech_blog
POSTGRES_USER=tech_blog
POSTGRES_PASSWORD=tech_blog

# JWT verifier (set one strategy)
# 1) HMAC:
AUTH_JWT_SECRET=
# 2) OIDC/JWK:
APP_AUTH_JWT_ISSUER_URI=
APP_AUTH_JWT_JWK_SET_URI=
# Optional fallback for HMAC if AUTH_JWT_SECRET is not used:
APP_AUTH_JWT_SHARED_SECRET=

# Claim name that contains user id (default: userId)
APP_AUTH_JWT_USER_ID_CLAIM=userId

# Share/Open Graph page
APP_SHARE_PUBLIC_BASE_URL=http://localhost:8080
APP_SHARE_DEFAULT_OG_IMAGE_URL=http://localhost:8080/og-default.png
APP_SHARE_DEFAULT_DESCRIPTION=A&I 기술 블로그
APP_SHARE_CACHE_MAX_AGE_SECONDS=60
APP_SHARE_CACHE_SHARED_MAX_AGE_SECONDS=300
APP_SHARE_CACHE_STALE_WHILE_REVALIDATE_SECONDS=600
